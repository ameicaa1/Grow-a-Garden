                local initialX = SliderButton.Position.X.Offset
                local trackSize = SliderTrack.AbsoluteSize.X
                local trackPos = SliderTrack.AbsolutePosition.X
                
                local con
                con = stepped:Connect(function()
                    if isdragging then
                        local percent = math.clamp((mouse.X - trackPos) / trackSize, 0, 1)
