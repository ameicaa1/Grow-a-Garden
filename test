            if #DropdownFrame:GetChildren() < 6 then
                DropdownFrame.Size = UDim2.new(1, 0, 0, DropdownFrame.Size.Y.Offset + 30)
            end
        end

        function dropFunctions:Remove(name)
            local foundIt
            for i, v in pairs(DropdownFrame:GetChildren()) do
                if foundIt then
                    canvasSize = canvasSize - 30
                    v.Position = UDim2.new(0, 5, 0, v.Position.Y.Offset - 30)
                    DropdownFrame.CanvasSize = UDim2.new(0, 0, 0, canvasSize + 5)
                end
                if v.Text == name then
                    foundIt = true
                    v:Destroy()
                    if #DropdownFrame:GetChildren() < 6 then
                        DropdownFrame.Size = UDim2.new(1, 0, 0, DropdownFrame.Size.Y.Offset - 30)
                    end
                end
            end
            if not foundIt then
                warn("The button you tried to remove didn't exist!")
            end
        end

        -- Add initial buttons
        for i, v in pairs(buttons) do
            dropFunctions:Button(v)
        end

        return dropFunctions
    end

